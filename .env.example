# Whop — platform (CreatorJobs) credentials. Server-side only, never expose to the client.
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
WHOP_COMPANY_ID=
# App id (biz app). Only used by the SDK's oauth module; safe to leave as-is for the demo.
WHOP_APP_ID=
# Leave unset for production (https://api.whop.com/api/v1). Set to
# https://sandbox-api.whop.com/api/v1 to run against Whop's sandbox — a
# separate environment with its own API key, company id, and webhook secret;
# swap all four together, not just the URL. Read by @whop/sdk directly.
WHOP_BASE_URL=

# Supabase — service role key is server-only. Never ship it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key powers the RLS-respecting auth client (magic-link sessions). Also server-only here.
SUPABASE_ANON_KEY=

# Public base URL of this deployment (used for KYC/checkout return_url). Optional in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
